{
  "name": "card-issuance-service",
  "version": "1.0.0",
  "description": "Card Issuance Service - Issues new payment cards with PCI-DSS compliant encryption",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:up": "node -r ts-node/register migrations/migrate.ts"
  },
  "keywords": [
    "card-issuance",
    "pci-dss",
    "payment-cards",
    "typescript",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4",
    "pino": "^8.16.1",
    "pino-http": "^8.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.9",
    "@types/jest": "^29.5.8",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "pg-mem": "^2.7.2",
    "testcontainers": "^10.3.1",
    "eslint": "^8.53.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "prettier": "^3.0.3"
  }
}
