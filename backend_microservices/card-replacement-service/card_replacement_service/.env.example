# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=card_replacement_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50

# Timeout
REQUEST_TIMEOUT_MS=15000

# Kafka (if needed for CardReplaced events)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=card-replacement-service
KAFKA_TOPIC_CARD_REPLACED=card.replaced
