# Server Configuration
NODE_ENV=development
PORT=3000
API_BASE_PATH=/api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transaction_validation
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=5000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# Logging
LOG_LEVEL=info

# Security
API_KEY_HEADER=X-API-Key
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10000

# Validation
VALIDATION_TIMEOUT_MS=1000
VALIDATION_MAX_RESPONSE_TIME_MS=500
DUPLICATE_TRANSACTION_WINDOW_SECONDS=120
CVV_MAX_FAILURES=3

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true
