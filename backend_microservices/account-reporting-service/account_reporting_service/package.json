{
  "name": "account-reporting-service",
  "version": "1.0.0",
  "description": "Account Reporting Service - Generates account-level reports including account status summaries, credit utilization analysis, and delinquency reports",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:latest": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback"
  },
  "keywords": [
    "account-reporting",
    "reports",
    "credit-analysis"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "knex": "^3.0.1",
    "zod": "^3.22.4",
    "pino": "^8.16.1",
    "pino-http": "^8.5.1",
    "pino-pretty": "^10.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.7",
    "@types/jest": "^29.5.8",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "prettier": "^3.0.3",
    "typescript": "^5.2.2",
    "tsx": "^4.1.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "pg-mem": "^2.8.1",
    "testcontainers": "^10.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
