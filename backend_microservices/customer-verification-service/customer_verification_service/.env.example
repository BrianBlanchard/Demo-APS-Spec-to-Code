# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=customer_verification
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# External Services
CREDIT_BUREAU_API_URL=https://api.creditbureau.example.com
CREDIT_BUREAU_API_KEY=your_api_key_here
GOVERNMENT_ID_API_URL=https://api.govid.example.com
GOVERNMENT_ID_API_KEY=your_api_key_here
FRAUD_DETECTION_API_URL=https://api.fraud.example.com
FRAUD_DETECTION_API_KEY=your_api_key_here
ADDRESS_VERIFICATION_API_URL=https://api.addressverify.example.com
ADDRESS_VERIFICATION_API_KEY=your_api_key_here

# Service Configuration
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY_MS=1000
REQUEST_TIMEOUT_MS=5000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000

# Kafka Configuration (for events)
KAFKA_BROKER_URL=localhost:9092
KAFKA_TOPIC_VERIFICATION_COMPLETED=verification.completed

# Security
JWT_SECRET=your_jwt_secret_here
JWT_ISSUER=customer-verification-service

# Fraud Detection Thresholds
FRAUD_RISK_HIGH_THRESHOLD=70
FICO_SCORE_MIN_THRESHOLD=550
