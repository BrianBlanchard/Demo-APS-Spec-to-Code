{
  "name": "customer-verification-service",
  "version": "1.0.0",
  "description": "Customer Identity Verification Service with KYC and fraud detection",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=lcov",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate:latest": "knex migrate:latest --knexfile ./knexfile.ts",
    "migrate:rollback": "knex migrate:rollback --knexfile ./knexfile.ts",
    "migrate:make": "knex migrate:make --knexfile ./knexfile.ts"
  },
  "keywords": [
    "verification",
    "kyc",
    "fraud-detection",
    "identity"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "knex": "^3.1.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "pino": "^8.16.2",
    "pino-http": "^8.5.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "pg-mem": "^2.8.1",
    "testcontainers": "^10.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
