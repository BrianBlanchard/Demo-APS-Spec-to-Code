# Server Configuration
NODE_ENV=development
PORT=3000
SERVICE_NAME=customer-profile-service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=customer_profile_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# Rate Limiting
RATE_LIMIT_GET_WINDOW_MS=60000
RATE_LIMIT_GET_MAX=500
RATE_LIMIT_PUT_WINDOW_MS=60000
RATE_LIMIT_PUT_MAX=100

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info
LOG_PRETTY_PRINT=true

# JWT Configuration (for validation)
JWT_SECRET=your-secret-key-here
JWT_ISSUER=customer-profile-service

# API Timeouts (in milliseconds)
API_TIMEOUT_GET=5000
API_TIMEOUT_PUT=10000

# Kafka Configuration (for events)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_CUSTOMER_UPDATED=customer.updated
