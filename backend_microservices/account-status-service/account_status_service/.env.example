# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=account_status_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ISSUER=account-status-service

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=account-status-service
KAFKA_TOPIC_STATUS_CHANGED=account.status.changed
KAFKA_TOPIC_CLOSED_WITH_BALANCE=account.closed.with.balance

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Request Timeout
REQUEST_TIMEOUT_MS=10000

# Notification Service
NOTIFICATION_SERVICE_URL=http://localhost:3001
NOTIFICATION_RETRY_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_MS=1000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
