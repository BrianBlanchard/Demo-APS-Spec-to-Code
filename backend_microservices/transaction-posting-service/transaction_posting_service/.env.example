# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=transaction_posting
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30000

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=transaction-posting-service
KAFKA_TOPIC_TRANSACTION_POSTED=transaction.posted

# Service Configuration
SERVICE_TOKEN=your-internal-service-token-here

# Logging
LOG_LEVEL=info

# CORS Configuration
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TRANSACTIONS=5000
