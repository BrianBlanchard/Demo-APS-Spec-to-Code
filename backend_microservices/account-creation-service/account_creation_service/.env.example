# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=account_service
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# API Configuration
API_BASE_PATH=/api
API_VERSION=v1
CAPABILITY_NAME=accounts

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50

# External Services
CUSTOMER_KYC_SERVICE_URL=http://localhost:3001/api/v1/kyc

# Account Configuration
DEFAULT_ACCOUNT_TERM_MONTHS=36
REISSUANCE_WINDOW_DAYS=60

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true
