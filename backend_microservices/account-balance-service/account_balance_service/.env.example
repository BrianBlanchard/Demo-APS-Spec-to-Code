# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=account_balance
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=30

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_ISSUER=account-balance-service

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=account-balance-service
KAFKA_TOPIC_BALANCE_UPDATED=balance-updated

# API Configuration
API_TIMEOUT_BALANCE_RETRIEVAL=2000
API_TIMEOUT_BALANCE_UPDATE=5000
RATE_LIMIT_PUBLIC=1000

# CORS Configuration
CORS_ORIGIN=*
