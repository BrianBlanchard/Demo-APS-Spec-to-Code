# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=customer_registration
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Security
ENCRYPTION_KEY=your-encryption-key-here
JWT_SECRET=your-jwt-secret-here

# External Services
CREDIT_BUREAU_API_URL=https://api.creditbureau.com
CREDIT_BUREAU_API_KEY=your-api-key-here
CREDIT_BUREAU_TIMEOUT=5000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*
