# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=card_lookup_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_SECONDS=120

# API Configuration
API_TIMEOUT_MS=3000
RATE_LIMIT_REQUESTS=500
RATE_LIMIT_WINDOW_MS=60000

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Security
JWT_SECRET=your-secret-key-here
